<b:includable id='postBodySnippet' var='post'>
  <article class='card-item'>
    
    <!-- 1. Badge Label (Version) -->
    <b:loop values='data:post.labels' var='item'>
      <b:if cond='data:item.name contains &quot;Version&quot;'>
        <div class='card-badge'><data:item.name/></div>
      </b:if>
    </b:loop>

    <!-- 2. Tombol Wishlist -->
    <button class='btn-wishlist' expr:onclick='&quot;addToCart(&quot; + data:post.id + &quot;)&quot;'>
      <svg viewBox='0 0 24 24' width='20' height='20' fill='currentColor'><path d='M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z'/></svg>
    </button>

    <!-- 3. Gambar dengan No-Image Placeholder -->
    <a class='card-img' expr:href='data:post.url'>
      <b:if cond='data:post.featuredImage'>
        <img expr:alt='data:post.title' expr:src='data:post.featuredImage.isResizable ? resizeImage(data:post.featuredImage, 600, &quot;16:9&quot;) : data:post.thumbnail' loading='lazy'/>
      <b:else/>
        <img alt='No Image' src='https://upload.wikimedia.org/wikipedia/commons/6/65/No-Image-Placeholder.svg' loading='lazy'/>
      </b:if>
    </a>

    <!-- 4. Body Konten -->
    <div class='card-body'>
      <h3 class='card-title'><a expr:href='data:post.url'><data:post.title/></a></h3>
      
      <!-- Flex Container Harga & Demo -->
      <div class='price-demo-wrapper'>
        <div class='price-info'>
           <b:loop values='data:post.labels' var='item'>
             <b:if cond='data:item.name contains &quot;Rp&quot;'>
               <div class='price-tag'><data:item.name/></div>
             </b:if>
           </b:loop>
           <div class='status-tag'>
             <b:if cond='data:post.labels any (l => l.name == &quot;Premium&quot;)'>PREMIUM<b:else/>Gratis</b:if>
           </div>
        </div>
        
        <b:loop values='data:post.enclosures' var='enclosure'>
          <b:if cond='data:enclosure.mimeType == &quot;Demo&quot;'>
            <a class='btn-demo' expr:href='data:enclosure.url' rel='nofollow'>Demo</a>
          </b:if>
        </b:loop>
      </div>
    </div>
  </article>
</b:includable>
